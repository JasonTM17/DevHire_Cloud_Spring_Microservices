{
  "name": "devhire-cloud-frontend",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-test-module-mocks src/__tests__/**/*.test.ts src/__tests__/**/*.test.tsx",
    "test:properties": "FAST_CHECK_NUM_RUNS=500 node --test src/__tests__/properties/**/*.property.test.ts",
    "e2e": "playwright test e2e/devhire-smoke.spec.ts e2e/code-assessment-flow.spec.ts e2e/assistant-smoke.spec.ts --project=chromium",
    "e2e:code-assessment": "node scripts/e2e-preview.mjs code-assessment",
    "e2e:mobile": "playwright test e2e/mobile-smoke.spec.ts --project=mobile-chrome",
    "e2e:preview": "node scripts/e2e-preview.mjs desktop",
    "e2e:preview:mobile": "node scripts/e2e-preview.mjs mobile",
    "e2e:all": "node scripts/e2e-preview.mjs all",
    "e2e:report": "playwright show-report",
    "screenshots": "playwright test e2e/portfolio-screenshots.spec.ts e2e/stitch-route-matrix.spec.ts e2e/ops-screenshots.spec.ts e2e/ops-evidence-render.spec.ts --project=chromium",
    "screenshots:stitch": "node scripts/e2e-preview.mjs stitch",
    "screenshots:promote": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/screenshot-promote.ps1 -Set All",
    "screenshots:ops": "playwright test e2e/ops-screenshots.spec.ts e2e/ops-evidence-render.spec.ts --project=chromium",
    "screenshots:ops-evidence": "playwright test e2e/ops-evidence-render.spec.ts --project=chromium",
    "check:contrast": "node scripts/check-contrast.mjs",
    "analyze": "ANALYZE=true next build",
    "check:bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@stomp/stompjs": "^7.3.0",
    "lucide-react": "1.14.0",
    "next": "16.2.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sockjs-client": "^1.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "24.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sockjs-client": "^1.5.4",
    "fast-check": "^3.23.0",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "dompurify": "3.4.2",
    "postcss": "8.5.10"
  }
}
