{
  "uid": "devhire-recruitment-funnel",
  "title": "DevHire Recruitment Funnel",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["devhire", "recruitment", "funnel"],
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Applications By Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "devhire_applications", "legendFormat": "{{status}}"}]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Application Status Transitions",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "devhire_application_status_transitions > 0", "legendFormat": "{{from}} -> {{to}}"}]
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Notifications By Type / Read",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "devhire_notifications", "legendFormat": "{{type}} read={{read}}"}]
    }
  ]
}
