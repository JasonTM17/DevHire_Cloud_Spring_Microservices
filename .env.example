# DevHire Cloud local development variables.
# Copy to .env for local Docker runs. Do not commit .env.

POSTGRES_USER=devhire
POSTGRES_PASSWORD=devhire_local_password
POSTGRES_DB=devhire
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

JWT_SECRET=local-dev-only-change-this-secret-with-at-least-32-characters
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

SPRING_PROFILES_ACTIVE=docker

SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
REDIS_HOST_PORT=6380
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HOST_PORT=29092
DEVHIRE_SEARCH_PROVIDER=opensearch
DEVHIRE_SEARCH_OPENSEARCH_URL=http://opensearch:9200
DEVHIRE_SEARCH_OPENSEARCH_INDEX=devhire_jobs
DEVHIRE_SEARCH_OPENSEARCH_AUTO_CREATE_INDEX=true
DEVHIRE_SEARCH_OPENSEARCH_FALLBACK_TO_POSTGRES=true
OPENSEARCH_INITIAL_ADMIN_PASSWORD=DevHireOpenSearch@123456
OPENSEARCH_HOST_PORT=9200
OPENSEARCH_TRANSPORT_HOST_PORT=9600
OPENSEARCH_DASHBOARDS_HOST_PORT=5601

GATEWAY_HOST_PORT=8080
FRONTEND_HOST_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
AUTH_HOST_PORT=8081
USER_HOST_PORT=8082
COMPANY_HOST_PORT=8083
JOB_HOST_PORT=8084
APPLICATION_HOST_PORT=8085
NOTIFICATION_HOST_PORT=8086
AUDIT_HOST_PORT=8087
AI_HOST_PORT=8088

PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
LOKI_HOST_PORT=3100
TEMPO_HOST_PORT=3200
TEMPO_GRPC_HOST_PORT=4317
OTEL_HTTP_HOST_PORT=4318
OTEL_METRICS_HOST_PORT=8889

AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
COMPANY_SERVICE_URL=http://company-service:8083
JOB_SERVICE_URL=http://job-service:8084
APPLICATION_SERVICE_URL=http://application-service:8085
NOTIFICATION_SERVICE_URL=http://notification-service:8086
AUDIT_SERVICE_URL=http://audit-service:8087

DEVHIRE_NOTIFICATION_EMAIL_ENABLED=false
DEVHIRE_NOTIFICATION_EMAIL_FROM=no-reply@devhire.local
DEVHIRE_NOTIFICATION_EMAIL_REPLY_TO=
DEVHIRE_NOTIFICATION_EMAIL_DASHBOARD_BASE_URL=http://localhost:8080
DEVHIRE_NOTIFICATION_EMAIL_BATCH_SIZE=25
DEVHIRE_NOTIFICATION_EMAIL_MAX_ATTEMPTS=5
DEVHIRE_NOTIFICATION_EMAIL_RETRY_INITIAL_DELAY_SECONDS=30
DEVHIRE_NOTIFICATION_EMAIL_RETRY_MAX_DELAY_SECONDS=900
DEVHIRE_NOTIFICATION_EMAIL_RATE_LIMIT_PER_MINUTE=60
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=false
SPRING_MAIL_SMTP_SSL_TRUST=
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=5000
MANAGEMENT_HEALTH_MAIL_ENABLED=false

# Gmail SMTP local profile:
# Copy this file to .env, then run scripts/configure-gmail-smtp.ps1.
# Never commit a real Gmail app password.
# DEVHIRE_NOTIFICATION_EMAIL_ENABLED=true
# DEVHIRE_NOTIFICATION_EMAIL_FROM=your-gmail-address@gmail.com
# DEVHIRE_NOTIFICATION_EMAIL_REPLY_TO=your-gmail-address@gmail.com
# DEVHIRE_NOTIFICATION_EMAIL_RATE_LIMIT_PER_MINUTE=30
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-gmail-address@gmail.com
# SPRING_MAIL_PASSWORD=your-google-app-password
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
# SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
# SPRING_MAIL_SMTP_SSL_TRUST=smtp.gmail.com

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://localhost:8080
GATEWAY_RATE_LIMIT_REPLENISH=20
GATEWAY_RATE_LIMIT_BURST=40

# Claude Haiku AI assistant.
# Never commit a real key. Store it in local .env, GitHub Secrets, AWS Secrets Manager, or Kubernetes Secret.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=900
DEVHIRE_AI_DEMO_FALLBACK_ENABLED=true
DEVHIRE_AI_PROVIDER_FAILURE_THRESHOLD=3
DEVHIRE_AI_PROVIDER_CIRCUIT_OPEN_SECONDS=120

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
