aws_region         = "ap-southeast-1"
environment        = "staging"
name_prefix        = "devhire-staging"
vpc_cidr           = "10.50.0.0/16"
availability_zones = ["ap-southeast-1a", "ap-southeast-1b", "ap-southeast-1c"]

# Cost guardrails: enable intentionally only when a staging AWS account is ready.
enable_nat_gateway = false
enable_eks         = false
enable_rds         = false
enable_redis       = false
enable_msk         = false
enable_opensearch  = false

extra_tags = {
  Owner              = "platform-team"
  CostCenter         = "recruitment-platform"
  DataClassification = "internal"
  ExpiresOn          = "set-before-apply"
}
