@baseUrl = http://localhost:8080
@adminEmail = admin@devhire.local
@adminPassword = Admin@123456
@employerEmail = employer@devhire.local
@employerPassword = Employer@123456
@candidateEmail = candidate@devhire.local
@candidatePassword = Candidate@123456

# Paste tokens from login responses into these variables when your HTTP client
# does not support response variable extraction.
@adminToken = paste-admin-access-token-here
@employerToken = paste-employer-access-token-here
@candidateToken = paste-candidate-access-token-here

@approvedCompanyId = 20000000-0000-0000-0000-000000000001
@publishedJobId = 30000000-0000-0000-0000-000000000001
@applicationId = 40000000-0000-0000-0000-000000000001
@notificationId = 50000000-0000-0000-0000-000000000001

### Admin login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Employer login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{employerEmail}}",
  "password": "{{employerPassword}}"
}

### Candidate login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{candidateEmail}}",
  "password": "{{candidatePassword}}"
}

### Current user
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{candidateToken}}

### Employer creates company
POST {{baseUrl}}/api/companies
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
  "name": "DevHire Portfolio Studio",
  "logoUrl": "https://cdn.devhire.local/logos/portfolio-studio.png",
  "website": "https://devhire.local",
  "size": "51-200",
  "industry": "Software",
  "description": "A portfolio company used to demonstrate company onboarding."
}

### Admin approves company
PATCH {{baseUrl}}/api/admin/companies/{{approvedCompanyId}}/approve
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "reason": "Company information verified"
}

### Employer creates job
POST {{baseUrl}}/api/jobs
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
  "companyId": "{{approvedCompanyId}}",
  "title": "Senior Java Backend Engineer",
  "description": "Build recruitment platform services using Spring Boot and Kafka.",
  "requirements": "Java 21, Spring Boot, PostgreSQL, Kafka, Docker",
  "benefits": "Hybrid work, learning budget, production engineering culture",
  "salaryMin": 3500,
  "salaryMax": 6500,
  "location": "Ho Chi Minh City",
  "level": "Senior",
  "type": "FULL_TIME",
  "skills": ["Java", "Spring Boot", "Kafka", "PostgreSQL"]
}

### Employer submits job for review
PATCH {{baseUrl}}/api/jobs/{{publishedJobId}}/submit-review
Authorization: Bearer {{employerToken}}

### Admin approves job
PATCH {{baseUrl}}/api/admin/jobs/{{publishedJobId}}/approve
Authorization: Bearer {{adminToken}}

### Candidate searches jobs
GET {{baseUrl}}/api/jobs?keyword=java&skill=Spring%20Boot&location=Ho%20Chi%20Minh&page=0&size=5&sort=publishedAt,desc
Authorization: Bearer {{candidateToken}}

### Candidate views job detail
GET {{baseUrl}}/api/jobs/{{publishedJobId}}
Authorization: Bearer {{candidateToken}}

### Candidate applies to job
POST {{baseUrl}}/api/jobs/{{publishedJobId}}/applications
Authorization: Bearer {{candidateToken}}
Content-Type: application/json

{
  "cvUrl": "https://cdn.devhire.local/cv/candidate-java.pdf",
  "coverLetter": "I have built similar systems using Spring Boot, Kafka and PostgreSQL."
}

### Candidate lists own applications
GET {{baseUrl}}/api/applications/me?page=0&size=10
Authorization: Bearer {{candidateToken}}

### Employer lists applications for job
GET {{baseUrl}}/api/employer/jobs/{{publishedJobId}}/applications?page=0&size=10
Authorization: Bearer {{employerToken}}

### Employer updates application status
PATCH {{baseUrl}}/api/applications/{{applicationId}}/status
Authorization: Bearer {{employerToken}}
Content-Type: application/json

{
  "status": "INTERVIEW",
  "note": "Technical interview scheduled"
}

### Candidate reads notifications
GET {{baseUrl}}/api/notifications?page=0&size=10
Authorization: Bearer {{candidateToken}}

### Mark notification as read
PATCH {{baseUrl}}/api/notifications/{{notificationId}}/read
Authorization: Bearer {{candidateToken}}

### Admin views audit logs
GET {{baseUrl}}/api/admin/audit-logs?action=approve%20job&page=0&size=20&sort=occurredAt,desc
Authorization: Bearer {{adminToken}}

### Candidate asks Claude AI assistant
POST {{baseUrl}}/api/ai/chat
Authorization: Bearer {{candidateToken}}
Content-Type: application/json

{
  "message": "Explain this microservices platform to a recruiter"
}

### Admin reindexes AI knowledge
POST {{baseUrl}}/api/admin/ai/knowledge/reindex
Authorization: Bearer {{adminToken}}
