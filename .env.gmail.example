# DevHire Cloud Gmail SMTP profile.
# Copy values into .env with scripts/configure-gmail-smtp.ps1.
# This template is safe to commit because it contains no real app password.

DEVHIRE_NOTIFICATION_EMAIL_ENABLED=true
DEVHIRE_NOTIFICATION_EMAIL_FROM=your-gmail-address@gmail.com
DEVHIRE_NOTIFICATION_EMAIL_REPLY_TO=your-gmail-address@gmail.com
DEVHIRE_NOTIFICATION_EMAIL_DASHBOARD_BASE_URL=http://localhost:8080
DEVHIRE_NOTIFICATION_EMAIL_BATCH_SIZE=25
DEVHIRE_NOTIFICATION_EMAIL_MAX_ATTEMPTS=5
DEVHIRE_NOTIFICATION_EMAIL_RETRY_INITIAL_DELAY_SECONDS=30
DEVHIRE_NOTIFICATION_EMAIL_RETRY_MAX_DELAY_SECONDS=900
DEVHIRE_NOTIFICATION_EMAIL_RATE_LIMIT_PER_MINUTE=30

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-gmail-address@gmail.com
SPRING_MAIL_PASSWORD=replace-with-google-app-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_SSL_TRUST=smtp.gmail.com
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=5000
SPRING_MAIL_SMTP_TIMEOUT=5000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=5000

MANAGEMENT_HEALTH_MAIL_ENABLED=true
